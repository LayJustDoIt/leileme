/* 全局样式 - 累了么 V1 小程序 */

page {
  --bg: #f6f7fb;
  --card: #ffffff;
  --text: #171a22;
  --muted: #7b8190;
  --line: #eceef4;
  --brand: #6c63ff;
  --brand2: #8b7dff;
  --brand-light: #efedff;
  --green: #22b573;
  --orange: #ff9f43;
  --pink: #ff6b9d;
  --blue: #4d8dff;

  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

view, text, button, input, image, scroll-view, swiper, swiper-item {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
  font-size: 28rpx;
  line-height: inherit;
  color: inherit;
}

button::after {
  border: 0;
}

/* 通用容器 */
.page-wrap {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.section {
  padding: 40rpx 32rpx 0;
}

.section-title {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 26rpx;
}

.section-title .title {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text);
}

.section-title .sub {
  font-size: 24rpx;
  color: var(--muted);
}

/* 卡片通用 */
.card {
  background: var(--card);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(33, 38, 58, 0.06);
  border: 1rpx solid var(--line);
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid var(--line);
  font-size: 24rpx;
  color: #555d6d;
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--brand), var(--brand2));
  color: #fff;
  border-radius: 28rpx;
  padding: 20rpx 30rpx;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(108, 99, 255, 0.24);
}

.btn-ghost {
  background: #fff;
  color: var(--brand);
  border-radius: 24rpx;
  padding: 18rpx 26rpx;
  font-size: 26rpx;
  font-weight: 700;
  border: 1rpx solid var(--brand);
}

/* 状态色 */
.text-muted { color: var(--muted); }
.text-brand { color: var(--brand); }
.text-green { color: var(--green); }
.text-orange { color: var(--orange); }

/* 工具类 */
.flex { display: flex; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1 { flex: 1; min-width: 0; }
.ellipsis-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 网络图片占位 */
.cover-fallback {
  background: linear-gradient(135deg, #efedff, #e8f9f2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--brand);
  font-weight: 700;
}
