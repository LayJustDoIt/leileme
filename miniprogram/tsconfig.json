{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": false,
    "experimentalDecorators": true,
    "module": "CommonJS",
    "target": "ES2020",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2020"],
    "types": [],
    "outDir": "./",
    "rootDir": "./",
    "noEmitOnError": false,
    "resolveJsonModule": true
  },
  "include": ["./**/*.ts", "./**/*.d.ts"],
  "exclude": ["node_modules"]
}
