.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  gap: 14rpx;
}

.emoji {
  font-size: 96rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.desc {
  font-size: 24rpx;
  color: var(--muted);
  text-align: center;
  line-height: 1.6;
}

.empty-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, var(--brand), var(--brand2));
  color: #fff;
  border-radius: 999rpx;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(108, 99, 255, 0.24);
}
