.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  gap: 14rpx;
}

.emoji {
  font-size: 96rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.desc {
  font-size: 24rpx;
  color: var(--muted);
  text-align: center;
}

.retry-btn {
  margin-top: 24rpx;
  background: #fff;
  color: var(--brand);
  border-radius: 999rpx;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  font-weight: 700;
  border: 1rpx solid var(--brand);
}
