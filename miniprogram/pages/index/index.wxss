.page-wrap {
  min-height: 100vh;
  padding-bottom: 0;
}

/* Hero */
.hero {
  padding: 32rpx 32rpx 16rpx;
}

.hero-card {
  background: linear-gradient(135deg, #6c63ff 0%, #8274ff 52%, #a190ff 100%);
  border-radius: 48rpx;
  padding: 44rpx;
  color: #fff;
  box-shadow: 0 36rpx 60rpx rgba(108, 99, 255, 0.28);
  position: relative;
  overflow: hidden;
}

.hero-card::before,
.hero-card::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.13);
}

.hero-card::before {
  width: 280rpx;
  height: 280rpx;
  right: -110rpx;
  top: -150rpx;
}

.hero-card::after {
  width: 160rpx;
  height: 160rpx;
  right: 110rpx;
  bottom: -90rpx;
}

.brand-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.brand {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.logo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.brand-name {
  font-size: 38rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.brand-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
  margin-top: 4rpx;
}

.weather-pill {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 24rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.greeting {
  position: relative;
  z-index: 1;
  margin-top: 48rpx;
}

.greeting-text {
  font-size: 50rpx;
  line-height: 1.3;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.greeting-sub {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
}

/* 搜索框 */
.search-wrap {
  padding: 0 32rpx;
  margin-top: 0;
  position: relative;
  z-index: 3;
}

.search-box {
  height: 100rpx;
  background: #fff;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 22rpx;
  box-shadow: 0 12rpx 36rpx rgba(33, 38, 58, 0.08);
  border: 1rpx solid rgba(108, 99, 255, 0.08);
}

.search-icon {
  font-size: 36rpx;
  color: var(--muted);
}

.search-placeholder {
  flex: 1;
  font-size: 28rpx;
  color: var(--muted);
}

.search-btn {
  background: linear-gradient(135deg, var(--brand), var(--brand2));
  color: #fff;
  border-radius: 24rpx;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(108, 99, 255, 0.24);
}

/* 热门词 */
.hot-tags {
  padding: 26rpx 32rpx 4rpx;
  white-space: nowrap;
}

.hot-tags .tag {
  display: inline-flex;
  align-items: center;
  margin-right: 14rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid var(--line);
  font-size: 24rpx;
  color: #555d6d;
}

.tag-hover {
  background: var(--brand-light) !important;
  color: var(--brand) !important;
}

/* 场景入口 */
.mood-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
}

.mood {
  background: #fff;
  border-radius: 28rpx;
  padding: 22rpx 6rpx 18rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(33, 38, 58, 0.04);
  border: 1rpx solid rgba(236, 238, 244, 0.9);
  overflow: hidden;
}

.mood-hover {
  transform: scale(0.94);
}

.mood-ico {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  margin: 0 auto 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.mood-1 .mood-ico { background: #fff3e5; }
.mood-2 .mood-ico { background: #eaf2ff; }
.mood-3 .mood-ico { background: #e8faf2; }
.mood-4 .mood-ico { background: #f0edff; }
.mood-5 .mood-ico { background: #fff0f5; }

.mood-name {
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 今日推荐横向卡片 */
.cards {
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.feature-card {
  display: inline-block;
  width: 480rpx;
  min-height: 280rpx;
  margin-right: 20rpx;
  border-radius: 40rpx;
  padding: 32rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(33, 38, 58, 0.06);
  vertical-align: top;
}

.feature-card:first-child {
  margin-left: 0;
}

.feature-1 { background: linear-gradient(135deg, #ff7c67, #ff9c66); }
.feature-2 { background: linear-gradient(135deg, #547cff, #7e8fff); }
.feature-3 { background: linear-gradient(135deg, #20b486, #4fd0a2); }

.feature-card::after {
  content: '';
  position: absolute;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.13);
  right: -70rpx;
  bottom: -90rpx;
}

.feature-hover {
  transform: scale(0.97);
}

.feature-arrow {
  position: absolute;
  right: 28rpx;
  top: 28rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  font-size: 26rpx;
}

.feature-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
  position: relative;
  z-index: 1;
}

.feature-title {
  font-size: 38rpx;
  font-weight: 800;
  margin: 16rpx 0 12rpx;
  position: relative;
  z-index: 1;
  line-height: 1.35;
  white-space: normal;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.feature-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.86);
  position: relative;
  z-index: 1;
  white-space: normal;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

/* 人群入口 */
.audience-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.audience {
  background: #fff;
  border-radius: 36rpx;
  padding: 28rpx;
  min-height: 220rpx;
  box-shadow: 0 8rpx 24rpx rgba(33, 38, 58, 0.04);
  border: 1rpx solid var(--line);
  position: relative;
  overflow: hidden;
}

.audience-hover {
  transform: scale(0.97);
}

.a-icon {
  font-size: 56rpx;
}

.a-name {
  font-size: 32rpx;
  font-weight: 800;
  margin: 16rpx 0 10rpx;
}

.a-desc {
  font-size: 24rpx;
  color: var(--muted);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 随机建议卡片 */
.random-card {
  background: linear-gradient(135deg, rgba(108, 99, 255, 0.96), rgba(76, 196, 160, 0.92));
  color: #fff;
  border-radius: 44rpx;
  padding: 36rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  box-shadow: 0 28rpx 60rpx rgba(76, 125, 145, 0.2);
  position: relative;
  overflow: hidden;
}

.random-card::before {
  content: '';
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  right: -140rpx;
  top: -170rpx;
}

.dice {
  flex-shrink: 0;
  width: 110rpx;
  height: 110rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  position: relative;
  z-index: 1;
}

.dice-spin {
  animation: spin 0.5s ease-in-out;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.random-content {
  flex: 1;
  position: relative;
  z-index: 1;
  min-width: 0;
}

.random-small {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.random-title {
  font-size: 34rpx;
  font-weight: 800;
  margin: 8rpx 0 12rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.random-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.84);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.random-btn {
  margin-top: 22rpx;
  padding: 14rpx 24rpx;
  border-radius: 24rpx;
  background: #fff;
  color: #5d56d8;
  font-size: 24rpx;
  font-weight: 800;
  display: inline-block;
}

.btn-hover {
  opacity: 0.8;
}

/* 猜你喜欢 */
.feed {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* TabBar 安全区占位，避免最后一张卡片被原生 TabBar 遮挡 */
.tabbar-safe-space {
  width: 100%;
  height: calc(180rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}
