.page-wrap {
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 搜索栏 */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 16rpx 32rpx 16rpx;
  background: var(--bg);
}

.search-box {
  height: 88rpx;
  background: #fff;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(33, 38, 58, 0.06);
  border: 1rpx solid var(--line);
}

.search-icon {
  font-size: 32rpx;
  color: var(--muted);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
  min-width: 0;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #e4e6ed;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
}

.search-btn {
  background: linear-gradient(135deg, var(--brand), var(--brand2));
  color: #fff;
  border-radius: 22rpx;
  padding: 14rpx 26rpx;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(108, 99, 255, 0.24);
}

/* 筛选条 */
.filter-bar {
  white-space: nowrap;
  padding: 8rpx 32rpx 16rpx;
}

.filter-pill {
  display: inline-flex;
  align-items: center;
  margin-right: 14rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 1rpx solid var(--line);
  font-size: 24rpx;
  color: #555d6d;
}

.filter-pill.active {
  background: var(--brand);
  color: #fff;
  border-color: var(--brand);
}

/* 兜底提示 */
.fallback-tip {
  margin: 12rpx 32rpx 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #fff3e5, #ffeed9);
  font-size: 24rpx;
  color: #a86b2c;
  line-height: 1.5;
}

/* 初始提示 */
.init-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
  gap: 24rpx;
}

.init-emoji {
  font-size: 120rpx;
}

.init-text {
  font-size: 26rpx;
  color: var(--muted);
  text-align: center;
}

/* 结果列表 */
.result-list {
  padding: 16rpx 32rpx 0;
}

.result-meta {
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 20rpx;
}

.feed {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: var(--muted);
}
