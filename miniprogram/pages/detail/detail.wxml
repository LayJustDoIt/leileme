<view class="page-wrap">
  <loading wx:if="{{loading}}" text="加载中…"></loading>

  <error-state
    wx:if="{{error && !detail}}"
    title="加载失败"
    desc="{{error}}"
    bind:retry="onRetry"
  ></error-state>

  <block wx:if="{{detail}}">
    <!-- 封面与标题区 -->
    <view class="hero" style="background: linear-gradient(135deg, {{typeColor}}, {{typeColor}}cc);">
      <view class="hero-bg"></view>
      <view class="hero-content">
        <view class="type-pill" style="background: rgba(255,255,255,0.22);">{{typeIcon}} {{typeName}}</view>
        <view class="title">{{detail.title}}</view>
        <view class="summary" wx:if="{{detail.summary}}">{{detail.summary}}</view>
        <view class="hero-meta">
          <text wx:if="{{detail.authorName}}">{{detail.authorName}}</text>
          <text wx:if="{{detail.sourceName}}"> · {{detail.sourceName}}</text>
          <text wx:if="{{timeText}}"> · {{timeText}}</text>
        </view>
      </view>
    </view>

    <!-- 标签 -->
    <view class="tags" wx:if="{{detail.tags && detail.tags.length}}">
      <view class="tag" wx:for="{{detail.tags}}" wx:key="*this">#{{item}}</view>
    </view>

    <!-- 正文 -->
    <view class="body-wrap" wx:if="{{detail.body}}">
      <rich-text class="body" nodes="{{detail.body}}"></rich-text>
    </view>
    <view class="body-wrap" wx:elif="{{detail.summary}}">
      <view class="body-plain">{{detail.summary}}</view>
    </view>
    <view class="body-empty" wx:else>
      <view class="body-empty-emoji">📝</view>
      <view class="body-empty-text">这篇内容正在整理中，先看看下面的相关推荐吧</view>
    </view>

    <!-- 互动栏 -->
    <view class="action-bar">
      <view class="action-item">
        <text class="action-icon">👁️</text>
        <text class="action-text">{{viewText}}</text>
      </view>
      <view class="action-item" bindtap="onToggleFavorite" hover-class="action-hover">
        <text class="action-icon">🤍</text>
        <text class="action-text">{{favText}}</text>
      </view>
      <view class="action-item" bindtap="onShareTap" hover-class="action-hover">
        <text class="action-icon">🔗</text>
        <text class="action-text">{{shareText}}</text>
      </view>
      <button class="action-fav-btn" bindtap="onToggleFavorite" hover-class="btn-hover">收藏</button>
    </view>

    <!-- 来源 -->
    <view class="source-row" wx:if="{{detail.sourceUrl || detail.sourceName}}">
      <view class="source-label">内容来源</view>
      <view class="source-value">
        <text>{{detail.sourceName || '累了么'}}</text>
        <text wx:if="{{detail.sourceUrl}}" class="source-link" data-url="{{detail.sourceUrl}}">查看原文 ›</text>
      </view>
    </view>

    <!-- 相关推荐 -->
    <view class="section" wx:if="{{detail.relatedContents && detail.relatedContents.length}}">
      <view class="section-title">
        <text class="title">相关推荐</text>
        <text class="sub">继续看看</text>
      </view>
      <view class="feed">
        <content-card
          wx:for="{{detail.relatedContents}}"
          wx:key="id"
          item="{{item}}"
          position="{{index}}"
          bind:tap="onRelatedTap"
        ></content-card>
      </view>
    </view>
  </block>
</view>
