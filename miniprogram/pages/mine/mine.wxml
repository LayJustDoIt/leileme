<view class="page-wrap">
  <!-- 用户头部 -->
  <view class="hero">
    <view class="hero-card">
      <view class="avatar">{{loggedIn ? '😊' : '🫠'}}</view>
      <view class="user-info">
        <view class="nickname">{{loggedIn ? (user.nickname || '累了么用户') : '访客用户'}}</view>
        <view class="sub">{{loggedIn ? '用户ID：' + user.id : '登录后可收藏与查看历史'}}</view>
      </view>
      <view wx:if="{{!loggedIn}}" class="login-btn {{loginLoading ? 'login-btn-loading' : ''}}" bindtap="onLoginTap">
        {{loginLoading ? '登录中...' : '微信登录'}}
      </view>
      <view wx:else class="logout-btn" bindtap="onLogoutTap">退出</view>
    </view>
  </view>

  <!-- 公告（来自 public-config.announcement） -->
  <view class="announce" wx:if="{{config && config.announcement}}">
    <view class="announce-emoji">📣</view>
    <view class="announce-text">{{config.announcement}}</view>
  </view>

  <!-- 随机建议 -->
  <view class="section" wx:if="{{randomTip}}">
    <view class="section-title">
      <text class="title">今天的小建议</text>
      <text class="sub" bindtap="onRefreshTip">换一个</text>
    </view>
    <view class="tip-card">
      <view class="tip-emoji">🎲</view>
      <view class="tip-content">
        <view class="tip-title">{{randomTip.title}}</view>
        <view class="tip-desc" wx:if="{{randomTip.summary}}">{{randomTip.summary}}</view>
      </view>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="section">
    <view class="section-title">
      <text class="title">更多</text>
    </view>
    <view class="menu-list">
      <view
        wx:for="{{menuList}}"
        wx:key="key"
        class="menu-item"
        data-key="{{item.key}}"
        bindtap="onMenuTap"
        hover-class="menu-hover"
      >
        <view class="menu-icon">{{item.icon}}</view>
        <view class="menu-main">
          <view class="menu-label">{{item.label}}</view>
          <view class="menu-desc">{{item.desc}}</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 版本号（来自 public-config.versionName） -->
  <view class="version-row" wx:if="{{config && config.versionName}}">
    {{config.appName || '累了么'}} v{{config.versionName}}
  </view>

  <!-- 开发信息（仅 dev 环境显示） -->
  <view class="section" wx:if="{{isDev}}">
    <view class="section-title">
      <text class="title">开发信息</text>
      <text class="sub">仅 dev 环境可见</text>
    </view>
    <view class="dev-card">
      <view class="dev-row">
        <text class="dev-label">环境</text>
        <text class="dev-value">{{envName}}</text>
      </view>
      <view class="dev-row">
        <text class="dev-label">API</text>
        <text class="dev-value ellipsis-1">{{apiBase}}</text>
      </view>
      <view class="dev-row">
        <text class="dev-label">Session</text>
        <text class="dev-value ellipsis-1" bindtap="onCopySession">{{sessionId}}</text>
      </view>
    </view>
  </view>

  <view class="tabbar-safe-space"></view>

  <!-- 关于我们弹窗 -->
  <view class="about-mask" wx:if="{{aboutVisible}}" bindtap="onCloseAbout">
    <view class="about-modal" catchtap>
      <view class="about-title">{{(config && config.aboutTitle) || '关于累了么'}}</view>
      <scroll-view class="about-scroll" scroll-y>
        <text class="about-content">{{(config && config.aboutContent) || '累了么是一个面向碎片时间的内容发现工具。'}}</text>
        <text class="about-contact" wx:if="{{config && config.contactText}}">{{config.contactText}}</text>
      </scroll-view>
      <view class="about-btn" bindtap="onCloseAbout">知道了</view>
    </view>
  </view>
</view>
