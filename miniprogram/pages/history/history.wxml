<view class="page-wrap">
  <!-- 头部 -->
  <view class="head" wx:if="{{list.length > 0 || total > 0}}">
    <view class="head-meta">共 {{total}} 条浏览记录</view>
    <view
      class="clear-btn {{clearing ? 'clear-btn-loading' : ''}}"
      catchtap="onClearTap"
      hover-class="clear-btn-hover"
    >{{clearing ? '清空中…' : '清空'}}</view>
  </view>

  <!-- 加载 -->
  <loading wx:if="{{loading}}" text="加载历史…"></loading>

  <!-- 错误 -->
  <error-state
    wx:if="{{error && list.length === 0 && !loading}}"
    title="历史加载失败"
    desc="{{error}}"
    bind:retry="onRetry"
  ></error-state>

  <!-- 列表错误（加载更多失败） -->
  <error-state
    wx:if="{{error && list.length > 0 && !loadingMore}}"
    title="加载失败"
    desc="{{error}}"
    bind:retry="onRetry"
  ></error-state>

  <!-- 空 -->
  <empty
    wx:if="{{!loading && !error && list.length === 0}}"
    icon="🕒"
    title="还没有浏览记录"
    desc="看过的内容会在这里出现"
  ></empty>

  <!-- 列表 -->
  <view class="feed-wrap" wx:if="{{list.length > 0}}">
    <view class="feed">
      <view class="history-item" wx:for="{{list}}" wx:key="id">
        <content-card
          item="{{item}}"
          position="{{index}}"
          bind:tap="onContentTap"
        ></content-card>
        <view class="history-meta">
          <view class="meta-left">
            <text class="meta-text">最近浏览 {{item._lastText}}</text>
            <text class="meta-dot">·</text>
            <text class="meta-text">{{item._browseText}}</text>
          </view>
          <view
            class="del-btn {{operatingId === item.id ? 'del-btn-loading' : ''}}"
            catchtap="onDeleteTap"
            data-id="{{item.id}}"
            hover-class="del-btn-hover"
          >{{operatingId === item.id ? '删除中…' : '删除'}}</view>
        </view>
      </view>
    </view>
    <loading wx:if="{{loadingMore}}" text="加载更多…"></loading>
    <view wx:if="{{!hasNext && list.length > 0}}" class="no-more">已经到底啦</view>
  </view>

  <!-- 底部安全区适配（非 tabBar 页面） -->
  <view class="safe-area-bottom"></view>
</view>
